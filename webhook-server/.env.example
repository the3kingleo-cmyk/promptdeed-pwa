# Shopify — get from Admin → Settings → Notifications → Webhooks (after registering)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# Shopify Admin API — get from Admin → Settings → Apps → Develop apps → Create private app
# Scopes needed: write_orders, write_fulfillments, read_orders, read_fulfillments
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_STORE_DOMAIN=vyycqv-vf.myshopify.com

# Email — use Gmail with an App Password, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your@gmail.com
